{
  "name": "@circuloos/verifier",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "dev": "DOTENV_CONFIG_PATH=env/.env pnpm exec ts-node-dev --respawn -r dotenv/config src/index.ts",
    "dev:local": "DOTENV_CONFIG_PATH=env/.env.local pnpm exec ts-node-dev --respawn -r dotenv/config src/index.ts",
    "dev:docker": "DOTENV_CONFIG_PATH=env/.env.docker pnpm exec ts-node-dev --respawn -r dotenv/config src/index.ts",
    "dev:test": "DOTENV_CONFIG_PATH=env/.env.test pnpm exec ts-node-dev --respawn -r dotenv/config src/index.ts",
    "build": "pnpm exec tsc -p .",
    "start": "node dist/index.js",
    "test": "vitest",
    "coverage": "vitest run --coverage",
    "docker:health": "node scripts/docker/healthcheck.js",
    "diagnose:credential": "node scripts/diagnose-credential.js"
  },
  "dependencies": {
    "@circuloos/common": "workspace:*",
    "@circuloos/file-store": "workspace:*",
    "@circuloos/test-utils": "workspace:*",
    "@fastify/cors": "^8.2.0",
    "@fastify/helmet": "^11.1.1",
    "@fastify/rate-limit": "^9.1.0",
    "@fastify/swagger": "^8.14.0",
    "@fastify/swagger-ui": "^1.7.1",
    "ethers": "^5.8.0",
    "fastify": "^4.0.0",
    "zod": "^4.1.13"
  },
  "optionalDependencies": {
    "better-sqlite3": "^12.4.6"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20.19.16",
    "@vitest/coverage-istanbul": "0.34.6",
    "@vitest/coverage-v8": "^0.34.6",
    "dotenv": "^17.2.3",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.9.2",
    "vitest": "^0.34.6"
  }
}