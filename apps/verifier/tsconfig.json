{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true,
  "rootDir": "src",
  "outDir": "dist",
    "types": ["node", "vitest"],
    "baseUrl": ".",
    "paths": {
      "@circuloos/test-utils": ["../../packages/test-utils/dist"],
      "@circuloos/issuer-server": ["../../apps/issuer/dist/index.js"]
    }
  },
  "include": ["src/**/*.ts", "src/**/*.d.ts"]
}
