{
  "name": "@circuloos/issuer",
  "version": "0.0.0",
  "packageManager": "pnpm@10.15.0",
  "private": true,
  "scripts": {
    "dev": "DOTENV_CONFIG_PATH=env/.env pnpm exec ts-node-dev --respawn -r dotenv/config src/index.ts",
    "dev:local": "DOTENV_CONFIG_PATH=env/.env.local pnpm exec ts-node-dev --respawn -r dotenv/config src/index.ts",
    "dev:docker": "DOTENV_CONFIG_PATH=env/.env.docker pnpm exec ts-node-dev --respawn -r dotenv/config src/index.ts",
    "dev:test": "DOTENV_CONFIG_PATH=env/.env.test pnpm exec ts-node-dev --respawn -r dotenv/config src/index.ts",
    "start": "node dist/index.js",
    "build": "pnpm exec tsc -p .",
    "test": "pnpm exec vitest",
    "coverage": "pnpm exec vitest run --coverage",
    "docker:health": "node scripts/docker/healthcheck.js"
  },
  "dependencies": {
    "@circuloos/common": "workspace:*",
    "@circuloos/file-store": "workspace:*",
    "@fastify/cookie": "^9.3.0",
    "@fastify/cors": "^8.5.0",
    "@fastify/helmet": "^11.1.1",
    "@fastify/rate-limit": "^9.1.0",
    "@fastify/swagger": "^8.14.0",
    "@fastify/swagger-ui": "^1.7.1",
    "@types/jsonwebtoken": "^9.0.10",
    "better-sqlite3": "^12.4.6",
    "ethers": "5.7.2",
    "fastify": "^4.23.0",
    "jsonwebtoken": "^9.0.2",
    "pdf-lib": "^1.17.1",
    "pino": "^10.1.0",
    "pino-pretty": "^13.1.3",
    "qrcode": "^1.5.4",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/mock-fs": "^4.13.4",
    "@types/node": "^20.19.16",
    "@types/qrcode": "^1.5.6",
    "@vitest/coverage-v8": "^0.34.6",
    "dotenv": "^17.2.3",
    "mock-fs": "^5.5.0",
    "ts-node-dev": "^2.0.0",
    "tsx": "^4.20.6",
    "typescript": "^5.9.2",
    "vitest": "^0.34.6"
  }
}