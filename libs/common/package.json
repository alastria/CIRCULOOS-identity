{
  "name": "@circuloos/common",
  "version": "0.0.0",
  "packageManager": "pnpm@10.15.0",
  "private": true,
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.js"
    },
    "./eip712": {
      "import": "./dist/eip712/index.js",
      "require": "./dist/eip712/index.js"
    }
  },
  "scripts": {
    "build": "pnpm exec tsc -p .",
    "dev": "pnpm exec ts-node-dev --respawn src/index.ts",
    "test": "pnpm exec vitest"
  },
  "dependencies": {
    "better-sqlite3": "^12.4.6",
    "dotenv": "^16.6.1",
    "ethers": "^5.8.0",
    "nodemailer": "^7.0.11",
    "pino": "^10.1.0",
    "pino-pretty": "^13.1.3",
    "sql.js": "^1.13.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.11",
    "@types/node": "^20.19.16",
    "@types/nodemailer": "^7.0.4",
    "@types/sql.js": "^1.4.9",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.9.2",
    "vitest": "^0.34.6"
  }
}