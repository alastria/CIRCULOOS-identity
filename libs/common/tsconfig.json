{
  "compilerOptions": {
    "types": ["vitest/globals", "node"],
    "target": "ES2020",
    "module": "CommonJS",
  "declaration": true,
  "outDir": "dist",
  "rootDir": "src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true
  },
  "include": ["src/**/*.ts", "src/**/*.d.ts"]
}
